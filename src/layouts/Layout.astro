---
import Navbar from '../components/Navbar.astro';
import '../assets/css/main.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Hacker_Log: Plataforma de inteligencia sobre ciberseguridad." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} — HACKER_LOG</title>
    <meta name="description" content={description}>
    <meta name="keywords" content="ciberseguridad, malware, hacking, inteligencia, hacking ético">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons (solo iconos) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-dark text-gray-200 font-sans antialiased">

    <Navbar />

    <main>
        <slot />
    </main>

    <!-- Footer -->
    <footer class="max-w-7xl mx-auto px-6 lg:px-8 mt-24 pb-12">
        <div class="border-t border-dark-300 pt-10 flex flex-col md:flex-row items-center justify-between gap-6">
            <a href="/" class="flex items-center gap-2 no-underline">
                <span class="font-mono font-bold text-sm text-gray-500 tracking-tight">HACKER<span class="text-red">_</span>LOG</span>
            </a>
            <div class="flex items-center gap-5 text-gray-600 text-lg">
                <a href="#" class="hover:text-red transition-colors"><i class="bi bi-github"></i></a>
                <a href="#" class="hover:text-red transition-colors"><i class="bi bi-twitter-x"></i></a>
                <a href="#" class="hover:text-red transition-colors"><i class="bi bi-rss"></i></a>
            </div>
            <p class="font-mono text-[10px] text-gray-600 tracking-widest uppercase">© 2026 · All rights reserved</p>
        </div>
    </footer>

</body>
</html>
