---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const categories = [...new Set(posts.map(p => p.data.category))].map(cat => ({
    name: cat,
    slug: cat.toLowerCase().replace(/\s+/g, '-')
}));
const baseUrl = import.meta.env.BASE_URL;
const normalizedBaseUrl = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const withBase = (path = '') => {
    if (!path) return normalizedBaseUrl;
    if (path.startsWith('#')) return `${normalizedBaseUrl}${path}`;

    const normalizedPath = path.startsWith('/') ? path.slice(1) : path;
    return `${normalizedBaseUrl}${normalizedPath}`;
};
---
<nav class="sticky top-0 z-50 w-full bg-dark/90 backdrop-blur-lg border-b border-dark-300">
    <div class="max-w-[88rem] mx-auto px-6 lg:px-8 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a href={withBase()} class="flex items-center gap-3 no-underline group">
            <div class="w-8 h-8 rounded bg-red/10 border border-red/30 flex items-center justify-center group-hover:border-red/60 transition-colors">
                <i class="bi bi-bug text-red text-sm"></i>
            </div>
            <span class="font-mono font-bold text-white text-sm tracking-tight">HACKER<span class="text-red">_</span>LOG</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-6 lg:gap-8 relative z-50">
            <a href={withBase()} id="nav-home" class="nav-link text-xs font-semibold text-gray-400 hover:text-white transition-colors uppercase tracking-widest">Inicio</a>

            <!-- Category Dropdown -->
            <div class="relative group">
                <button class="flex items-center gap-1 nav-link text-xs font-semibold text-gray-400 hover:text-white transition-colors uppercase tracking-widest cursor-default">
                    Categorias <i class="bi bi-chevron-down text-[10px] opacity-70 group-hover:rotate-180 transition-transform"></i>
                </button>
                <div class="absolute top-full left-0 mt-2 w-48 bg-dark-100 border border-dark-300 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 overflow-hidden z-50">
                    <div class="p-2 flex flex-col gap-1">
                        {categories.map(cat => (
                            <a href={withBase(`category/${cat.slug}`)} class="block px-3 py-2 text-xs text-gray-400 hover:text-white hover:bg-dark-200 rounded-lg transition-colors font-mono uppercase tracking-wider">
                                {cat.name}
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <a href={withBase('submit-post')} id="nav-submit" class="nav-link text-xs font-semibold text-gray-400 hover:text-white transition-colors uppercase tracking-widest">Subir Post</a>
            <a href={withBase('hall-of-fame')} id="nav-hall" class="nav-link text-xs font-semibold text-gray-400 hover:text-white transition-colors uppercase tracking-widest">Hall of Fame</a>
            <a href={withBase('about')} id="nav-about" class="nav-link text-xs font-semibold text-gray-400 hover:text-white transition-colors uppercase tracking-widest">Nosotros</a>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4">
            <!-- Search -->
            <div class="hidden lg:flex items-center relative">
                <i class="bi bi-search absolute left-3 text-gray-500 text-xs"></i>
                <input
                    type="text"
                    id="search-db-nav"
                    placeholder="Buscar..."
                    class="bg-dark-100 border border-dark-300 rounded-lg pl-9 pr-4 py-2 text-xs text-gray-300 w-44 focus:w-56 focus:border-red/50 focus:outline-none transition-all placeholder:text-gray-600 font-mono"
                />
            </div>
            <!-- CTA -->
            <a href={withBase('submit-post')} class="hidden sm:inline-flex items-center gap-2 bg-red hover:bg-red-dark text-white text-[11px] font-bold uppercase tracking-wider px-5 py-2.5 rounded-lg transition-colors no-underline">
                Enviar reporte
            </a>
            <!-- Mobile toggle -->
            <button id="mobile-toggle" class="md:hidden text-gray-400 hover:text-white transition-colors" aria-label="Menu">
                <i class="bi bi-list text-2xl"></i>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-dark-300 bg-dark max-h-[80vh] overflow-y-auto">
        <div class="px-6 py-4 flex flex-col gap-3">
            <a href={withBase()} class="text-sm text-gray-400 hover:text-white transition-colors py-2 no-underline">Inicio</a>

            <div class="flex flex-col gap-2">
                <p class="text-[10px] text-gray-500 font-mono uppercase tracking-widest mt-2 mb-1">Categorias</p>
                <div class="flex flex-col gap-2 pl-3 border-l-2 border-dark-300">
                    {categories.map(cat => (
                        <a href={withBase(`category/${cat.slug}`)} class="text-[13px] text-gray-400 hover:text-white transition-colors py-1 no-underline font-mono uppercase tracking-wider">{cat.name}</a>
                    ))}
                </div>
            </div>

            <a href={withBase('submit-post')} class="text-sm text-gray-400 hover:text-white transition-colors py-2 no-underline">Subir Post</a>
            <a href={withBase('hall-of-fame')} class="text-sm text-gray-400 hover:text-white transition-colors py-2 no-underline">Hall of Fame</a>
            <a href={withBase('about')} class="text-sm text-gray-400 hover:text-white transition-colors py-2 no-underline">Nosotros</a>
        </div>
    </div>
</nav>

<script define:vars={{ baseUrl }}>
    // Mobile menu toggle
    document.getElementById('mobile-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // Active link
    const path = window.location.pathname;
    const basePath = baseUrl === '/' ? '' : baseUrl.replace(/\/$/, '');
    const normalizedPath = basePath && path.startsWith(basePath) ? path.slice(basePath.length) || '/' : path;

    if (normalizedPath === '/' || normalizedPath === '/index.html') {
        document.getElementById('nav-home')?.classList.add('text-white');
    } else if (normalizedPath.includes('submit-post')) {
        document.getElementById('nav-submit')?.classList.add('text-white');
    } else if (normalizedPath.includes('hall-of-fame')) {
        document.getElementById('nav-hall')?.classList.add('text-white');
    } else if (normalizedPath.includes('about')) {
        document.getElementById('nav-about')?.classList.add('text-white');
    }

    // Sync search
    const navSearch = document.getElementById('search-db-nav') as HTMLInputElement;
    const mainSearch = document.getElementById('search-db') as HTMLInputElement;
    if (navSearch && mainSearch) {
        navSearch.addEventListener('input', (e) => {
            const target = e.target as HTMLInputElement;
            mainSearch.value = target.value;
            mainSearch.dispatchEvent(new Event('input', { bubbles: true }));
        });
    }
</script>

