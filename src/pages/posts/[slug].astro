---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import PostTags from '../../components/PostTags.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { sortByPostDateDesc, toIsoDateString } from '../../lib/dates';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const sameCategoryPosts = sortByPostDateDesc(allPosts.filter(p => p.slug !== post.slug && p.data.category === post.data.category)).slice(0, 5);

const latestPosts = sortByPostDateDesc(allPosts.filter(p => p.slug !== post.slug)).slice(0, 5);

const sidebarEventPosts = sortByPostDateDesc(allPosts.filter(p => p.slug !== post.slug && p.data.category.toLowerCase() === 'eventos')).slice(0, 3);

const publishedTime = toIsoDateString(post.data.date);
const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.summary,
  datePublished: publishedTime,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  image: new URL(post.data.image, Astro.url).href,
  mainEntityOfPage: Astro.url.href,
});

const socialLinks = [
  { label: 'GitHub', icon: 'bi-github', href: 'https://github.com/adolfoalvar3z/h4ck.cl', handle: '@adolfoalvar3z' },
  { label: 'X / Twitter', icon: 'bi-twitter-x', href: 'https://x.com/h4ck_cl', handle: '@h4ck_cl' },
  { label: 'RSS Feed', icon: 'bi-rss', href: `${import.meta.env.BASE_URL}rss.xml`, handle: 'Suscribete' },
];
---

<Layout title={post.data.title} description={post.data.summary} image={post.data.image} type="article" publishedTime={publishedTime}>
  <script type="application/ld+json" set:html={articleJsonLd}></script>
  <article>
    <div class="relative h-[45vh] min-h-[320px]">
      <img src={post.data.image} alt={post.data.title} loading="eager" fetchpriority="high" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/30"></div>
    </div>

    <div class="max-w-[88rem] mx-auto px-6 lg:px-8 -mt-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_320px] gap-10 xl:gap-14">
        <div class="min-w-0 max-w-3xl">
          <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 text-gray-500 hover:text-white text-xs font-mono transition-colors mb-8 no-underline uppercase tracking-wider">
            <i class="bi bi-arrow-left"></i> Volver al feed
          </a>

          <div class="mb-6">
            <div class="mb-4">
              <CategoryBadge category={post.data.category} />
            </div>

            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white leading-[1.15] tracking-tight mb-6">
              {post.data.title}
            </h1>
            <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500 font-mono">
              <span class="flex items-center gap-1.5"><i class="bi bi-person"></i> {post.data.author}</span>
              <span class="text-dark-300">·</span>
              <span class="flex items-center gap-1.5"><i class="bi bi-calendar3"></i> {post.data.date}</span>
              <span class="text-dark-300">·</span>
              <span class="flex items-center gap-1.5"><i class="bi bi-clock"></i> {post.data.readTime}</span>
            </div>

            <div class="mt-5">
              <PostTags tags={post.data.tags} size="md" />
            </div>

            <div class="mt-8 border-t border-dark-300 pt-6">
              <ShareButtons title={post.data.title} description={post.data.summary || post.data.title} url={Astro.url} />
            </div>
          </div>

          <hr class="border-dark-300 mb-10" />

          <div class="post-content pb-10">
            <Content />
          </div>

          {sameCategoryPosts.length > 0 && (
            <div class="category-nav bg-dark-100 border border-dark-300 rounded-xl p-5 mb-8">
              <div class="flex items-center gap-2 mb-4">
                <i class="bi bi-folder2 text-red text-sm"></i>
                <span class="text-[11px] font-mono text-gray-400 uppercase tracking-wider">Mas en</span>
                <a href={`${import.meta.env.BASE_URL}category/${post.data.category.toLowerCase().replace(/\s+/g, '-')}`} class="text-[11px] font-mono text-red font-bold uppercase tracking-wider no-underline hover:text-red-light transition-colors">
                  {post.data.category}
                </a>
              </div>
              <div class="flex flex-col gap-2">
                {sameCategoryPosts.map(p => (
                  <a
                    href={`${import.meta.env.BASE_URL}posts/${p.slug}`}
                    class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-dark-200 transition-all no-underline group/catlink"
                  >
                    <div class="w-10 h-10 rounded-lg overflow-hidden shrink-0 border border-dark-300">
                      <img src={p.data.image} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <h4 class="text-xs font-semibold text-gray-300 group-hover/catlink:text-white transition-colors truncate">
                        {p.data.title}
                      </h4>
                      <span class="text-[10px] font-mono text-gray-600">{p.data.date}</span>
                    </div>
                    <i class="bi bi-chevron-right text-[10px] text-gray-600 group-hover/catlink:text-red transition-colors"></i>
                  </a>
                ))}
              </div>
            </div>
          )}

          <RelatedPosts
            currentSlug={post.slug}
            currentCategory={post.data.category}
            currentTags={post.data.tags}
          />

          <div class="post-nav flex gap-4 mt-12 pb-20">
            {(() => {
              const sorted = sortByPostDateDesc(allPosts);
              const currentIdx = sorted.findIndex(p => p.slug === post.slug);
              const prev = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
              const next = currentIdx > 0 ? sorted[currentIdx - 1] : null;
              return (
                <>
                  {prev ? (
                    <a href={`${import.meta.env.BASE_URL}posts/${prev.slug}`} class="flex-1 group bg-dark-100 border border-dark-300 rounded-xl p-4 no-underline hover:border-red/30 transition-all hover:-translate-y-0.5">
                      <span class="text-[10px] font-mono text-gray-600 uppercase tracking-wider flex items-center gap-1 mb-2">
                        <i class="bi bi-arrow-left text-[8px]"></i> Anterior
                      </span>
                      <span class="text-sm font-semibold text-gray-300 group-hover:text-white transition-colors line-clamp-1 block">
                        {prev.data.title}
                      </span>
                    </a>
                  ) : <div class="flex-1"></div>}
                  {next ? (
                    <a href={`${import.meta.env.BASE_URL}posts/${next.slug}`} class="flex-1 group bg-dark-100 border border-dark-300 rounded-xl p-4 no-underline hover:border-red/30 transition-all hover:-translate-y-0.5 text-right">
                      <span class="text-[10px] font-mono text-gray-600 uppercase tracking-wider flex items-center justify-end gap-1 mb-2">
                        Siguiente <i class="bi bi-arrow-right text-[8px]"></i>
                      </span>
                      <span class="text-sm font-semibold text-gray-300 group-hover:text-white transition-colors line-clamp-1 block">
                        {next.data.title}
                      </span>
                    </a>
                  ) : <div class="flex-1"></div>}
                </>
              );
            })()}
          </div>
        </div>

        <aside class="lg:pt-32">
          <div class="lg:sticky lg:top-24 space-y-5 pb-20">
            <section class="bg-dark-100 border border-dark-300 rounded-xl p-5">
              <div class="flex items-center gap-2 mb-4">
                <div class="w-7 h-7 rounded bg-red/10 border border-red/30 flex items-center justify-center">
                  <i class="bi bi-clock-history text-red text-xs"></i>
                </div>
                <h3 class="text-sm font-bold text-white">Ultimos posts</h3>
              </div>
              <div class="space-y-2">
                {latestPosts.map((item) => (
                  <a href={`${import.meta.env.BASE_URL}posts/${item.slug}`} class="group block no-underline rounded-lg border border-dark-300 bg-dark/40 px-3 py-2.5 hover:border-red/30 hover:bg-dark-200 transition-all">
                    <h4 class="text-xs font-semibold text-gray-300 group-hover:text-white transition-colors line-clamp-2">
                      {item.data.title}
                    </h4>
                    <p class="text-[10px] text-gray-600 font-mono mt-1">{item.data.date}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="bg-dark-100 border border-dark-300 rounded-xl p-5">
              <div class="flex items-center gap-2 mb-4">
                <div class="w-7 h-7 rounded bg-red/10 border border-red/30 flex items-center justify-center">
                  <i class="bi bi-broadcast-pin text-red text-xs"></i>
                </div>
                <h3 class="text-sm font-bold text-white">Redes sociales</h3>
              </div>
              <div class="space-y-2.5">
                {socialLinks.map((social) => (
                  <a href={social.href} class="flex items-center justify-between gap-3 no-underline rounded-lg border border-dark-300 bg-dark/40 px-3 py-2.5 hover:border-red/30 hover:bg-dark-200 transition-all group">
                    <div class="flex items-center gap-2.5">
                      <i class={`bi ${social.icon} text-gray-400 group-hover:text-red transition-colors`}></i>
                      <span class="text-xs font-medium text-gray-300 group-hover:text-white transition-colors">{social.label}</span>
                    </div>
                    <span class="text-[10px] font-mono text-gray-600">{social.handle}</span>
                  </a>
                ))}
              </div>
            </section>

            <section class="bg-dark-100 border border-dark-300 rounded-xl p-5">
              <div class="flex items-center gap-2 mb-4">
                <div class="w-7 h-7 rounded bg-red/10 border border-red/30 flex items-center justify-center">
                  <i class="bi bi-calendar-event text-red text-xs"></i>
                </div>
                <h3 class="text-sm font-bold text-white">Eventos</h3>
              </div>
              {sidebarEventPosts.length > 0 ? (
                <div class="space-y-2.5">
                  {sidebarEventPosts.map((event) => (
                    <a href={`${import.meta.env.BASE_URL}posts/${event.slug}`} class="block no-underline rounded-lg border border-dark-300 bg-dark/40 px-3 py-3 hover:border-red/30 hover:bg-dark-200 transition-all group">
                      <p class="text-[10px] font-mono text-red uppercase tracking-wider mb-1">{event.data.date}</p>
                      <h4 class="text-xs font-semibold text-gray-300 group-hover:text-white transition-colors line-clamp-2">
                        {event.data.title}
                      </h4>
                    </a>
                  ))}
                </div>
              ) : (
                <p class="text-xs text-gray-500 leading-relaxed">No hay eventos publicados por ahora.</p>
              )}
            </section>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

