---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostTags from '../../components/PostTags.astro';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    const authors = [...new Set(posts.map(p => p.data.author || 'Anonymous'))];

    return authors.map(author => ({
        params: { author: author.toLowerCase().replace(/\s+/g, '-') },
        props: { 
            authorName: author,
            posts: posts.filter(p => (p.data.author || 'Anonymous') === author)
                .sort((a, b) => b.data.date.localeCompare(a.data.date))
        },
    }));
}

const { authorName, posts } = Astro.props;

// For sidebar or stats
const allPosts = await getCollection('blog');
const allAuthors = [...new Set(allPosts.map(p => p.data.author || 'Anonymous'))];
const authorCounts = allAuthors.map(auth => ({
    name: auth,
    slug: auth.toLowerCase().replace(/\s+/g, '-'),
    count: allPosts.filter(p => (p.data.author || 'Anonymous') === auth).length,
    active: auth === authorName,
})).sort((a, b) => b.count - a.count);
---

<Layout title={`${authorName} — Perfil Op`} description={`Expediente y reportes de inteligencia filtrados por: ${authorName}`}>

    <section class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
        <!-- Header -->
        <div class="mb-14">
            <a href={`${import.meta.env.BASE_URL}hall-of-fame`} class="inline-flex items-center gap-2 text-gray-500 hover:text-white text-xs font-mono transition-colors mb-8 no-underline uppercase tracking-wider">
                <i class="bi bi-arrow-left"></i> Volver al muro
            </a>

            <div class="flex items-center gap-6 mb-4">
                <div class="w-20 h-20 rounded-lg bg-dark-100 border border-dark-300 flex items-center justify-center p-2 overflow-hidden shadow-lg shadow-red/5">
                    <img src={`https://api.dicebear.com/7.x/bottts/svg?seed=${authorName}`} alt={authorName} class="w-full h-full object-contain" />
                </div>
                <div>
                    <p class="text-[11px] text-gray-500 font-mono uppercase tracking-widest mb-1 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]"></span>
                        Operador_Activo
                    </p>
                    <h1 class="text-3xl md:text-5xl font-black text-white tracking-tight uppercase glitch-title" data-text={authorName}>{authorName}</h1>
                </div>
            </div>
            <p class="text-gray-400 text-sm max-w-2xl mt-4">
                Expediente clasificado. Mostrando {posts.length} {posts.length === 1 ? 'misión completada' : 'misiones completadas'} bajo este alias.
            </p>
        </div>

        <div class="flex flex-col lg:flex-row gap-10">
            <!-- Posts -->
            <div class="flex-1">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {posts.map(post => (
                        <article class="group bg-dark-100 border border-dark-300 rounded-xl overflow-hidden hover:border-red/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-red/5 flex flex-col">
                            <!-- Image -->
                            <div class="aspect-video overflow-hidden relative">
                                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-dark-100 to-transparent opacity-50"></div>
                                <a href={`${import.meta.env.BASE_URL}category/${post.data.category.toLowerCase().replace(/\s+/g, '-')}`} class="absolute top-3 left-3 bg-dark/80 backdrop-blur-sm text-gray-300 text-[10px] font-mono font-bold uppercase tracking-wider px-2.5 py-1 rounded-md border border-dark-300 no-underline hover:text-red hover:border-red/30 transition-all">
                                    {post.data.category}
                                </a>
                            </div>

                            <!-- Content -->
                            <div class="p-5 flex flex-col flex-grow">
                                <div class="flex items-center gap-2 text-[11px] text-gray-500 font-mono mb-3">
                                    <i class="bi bi-calendar3"></i>
                                    <span>{post.data.date}</span>
                                    <span class="text-dark-300">·</span>
                                    <span>{post.data.readTime}</span>
                                </div>

                                <h3 class="text-lg font-bold text-white leading-snug mb-3 group-hover:text-red transition-colors">
                                    {post.data.title}
                                </h3>

                                <p class="text-[13px] text-gray-400 leading-relaxed mb-4 flex-grow line-clamp-3">
                                    {post.data.summary}
                                </p>

                                <PostTags tags={post.data.tags} />

                                <a href={`${import.meta.env.BASE_URL}posts/${post.slug}`} class="mt-4 inline-flex items-center gap-2 text-red text-xs font-semibold no-underline group/link hover:gap-3 transition-all">
                                    Leer protocolo
                                    <i class="bi bi-arrow-right transition-transform group-hover/link:translate-x-1"></i>
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            </div>

            <!-- Sidebar: Authors Directory -->
            <aside class="lg:w-72 shrink-0">
                <div class="sticky top-24">
                    <div class="bg-dark-100 border border-dark-300 rounded-xl p-5">
                        <h3 class="text-xs font-bold text-white uppercase tracking-widest mb-5 flex items-center gap-2">
                            <i class="bi bi-shield-check text-red text-sm"></i>
                            Directorio_Agentes
                        </h3>
                        <nav class="flex flex-col gap-1 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
                            {authorCounts.map(auth => (
                                <a 
                                    href={`${import.meta.env.BASE_URL}author/${auth.slug}`}
                                    class:list={[
                                        "flex items-center justify-between px-3 py-2.5 rounded-lg text-xs font-mono transition-all no-underline",
                                        auth.active 
                                            ? "bg-red/10 text-red border border-red/20" 
                                            : "text-gray-400 hover:text-white hover:bg-dark-200"
                                    ]}
                                >
                                    <div class="flex items-center gap-2 truncate">
                                        <div class="w-5 h-5 rounded-sm bg-dark border border-dark-300 flex items-center justify-center shrink-0">
                                            <img src={`https://api.dicebear.com/7.x/bottts/svg?seed=${auth.name}`} class="w-full h-full object-contain opacity-80" />
                                        </div>
                                        <span class="uppercase tracking-wider truncate">{auth.name}</span>
                                    </div>
                                    <span class:list={[
                                        "text-[10px] px-2 py-0.5 rounded-full shrink-0",
                                        auth.active ? "bg-red/20 text-red" : "bg-dark-200 text-gray-600"
                                    ]}>
                                        {auth.count}
                                    </span>
                                </a>
                            ))}
                        </nav>
                        
                        <!-- Mini CSS for scrollbar -->
                        <style>
                            .custom-scrollbar::-webkit-scrollbar {
                                width: 4px;
                            }
                            .custom-scrollbar::-webkit-scrollbar-track {
                                background: transparent;
                            }
                            .custom-scrollbar::-webkit-scrollbar-thumb {
                                background: #333;
                                border-radius: 10px;
                            }
                            .custom-scrollbar::-webkit-scrollbar-thumb:hover {
                                background: #555;
                            }
                        </style>
                    </div>
                </div>
            </aside>
        </div>
    </section>

</Layout>
