---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostTags from '../../components/PostTags.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    const allTags = [...new Set(posts.flatMap(p => p.data.tags))];

    return allTags.map(tag => ({
        params: { tag: tag.toLowerCase() },
        props: {
            tag,
            posts: posts.filter(p => p.data.tags.some(t => t.toLowerCase() === tag.toLowerCase()))
                .sort((a, b) => b.data.date.localeCompare(a.data.date))
        },
    }));
}

const { tag, posts } = Astro.props;

// Get all tags for sidebar
const allPosts = await getCollection('blog');
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
const tagCounts = allTags.map(t => ({
    name: t,
    slug: t.toLowerCase(),
    count: allPosts.filter(p => p.data.tags.some(pt => pt.toLowerCase() === t.toLowerCase())).length,
    active: t.toLowerCase() === tag.toLowerCase(),
})).sort((a, b) => b.count - a.count);
---

<Layout title={`#${tag} — Tag`} description={`Todos los reportes con la etiqueta: ${tag}`}>

    <section class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
        <!-- Header -->
        <div class="mb-14">
            <a href="/" class="inline-flex items-center gap-2 text-gray-500 hover:text-white text-xs font-mono transition-colors mb-8 no-underline uppercase tracking-wider">
                <i class="bi bi-arrow-left"></i> Volver al feed
            </a>

            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-lg bg-red/10 border border-red/30 flex items-center justify-center">
                    <i class="bi bi-hash text-red text-xl"></i>
                </div>
                <div>
                    <p class="text-[11px] text-gray-500 font-mono uppercase tracking-widest mb-1">Tag</p>
                    <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight">#{tag}</h1>
                </div>
            </div>
            <p class="text-gray-400 text-sm max-w-2xl">
                {posts.length} {posts.length === 1 ? 'reporte encontrado' : 'reportes encontrados'} con esta etiqueta.
            </p>
        </div>

        <div class="flex flex-col lg:flex-row gap-10">
            <!-- Posts -->
            <div class="flex-1">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {posts.map(post => (
                        <article class="group bg-dark-100 border border-dark-300 rounded-xl overflow-hidden hover:border-red/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-red/5 flex flex-col">
                            <div class="aspect-video overflow-hidden relative">
                                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-dark-100 to-transparent opacity-50"></div>
                                <span class="absolute top-3 left-3 bg-dark/80 backdrop-blur-sm text-gray-300 text-[10px] font-mono font-bold uppercase tracking-wider px-2.5 py-1 rounded-md border border-dark-300">
                                    {post.data.category}
                                </span>
                            </div>

                            <div class="p-5 flex flex-col flex-grow">
                                <div class="flex items-center gap-2 text-[11px] text-gray-500 font-mono mb-3">
                                    <i class="bi bi-calendar3"></i>
                                    <span>{post.data.date}</span>
                                    <span class="text-dark-300">·</span>
                                    <span>{post.data.readTime}</span>
                                </div>

                                <h3 class="text-lg font-bold text-white leading-snug mb-3 group-hover:text-red transition-colors">
                                    {post.data.title}
                                </h3>

                                <p class="text-[13px] text-gray-400 leading-relaxed mb-4 flex-grow line-clamp-3">
                                    {post.data.summary}
                                </p>

                                <PostTags tags={post.data.tags} />

                                <a href={`/posts/${post.slug}`} class="mt-4 inline-flex items-center gap-2 text-red text-xs font-semibold no-underline group/link hover:gap-3 transition-all">
                                    Leer más
                                    <i class="bi bi-arrow-right transition-transform group-hover/link:translate-x-1"></i>
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            </div>

            <!-- Sidebar: All Tags -->
            <aside class="lg:w-72 shrink-0">
                <div class="sticky top-24">
                    <div class="bg-dark-100 border border-dark-300 rounded-xl p-5">
                        <h3 class="text-xs font-bold text-white uppercase tracking-widest mb-5 flex items-center gap-2">
                            <i class="bi bi-tags text-red text-sm"></i>
                            Todas las etiquetas
                        </h3>
                        <div class="flex flex-wrap gap-2">
                            {tagCounts.map(t => (
                                <a 
                                    href={`/tags/${t.slug}`}
                                    class:list={[
                                        "inline-flex items-center gap-1.5 text-[11px] font-mono px-2.5 py-1.5 rounded-lg transition-all no-underline",
                                        t.active 
                                            ? "bg-red/10 text-red border border-red/20" 
                                            : "bg-dark-200 text-gray-400 border border-dark-300 hover:text-white hover:border-dark-400"
                                    ]}
                                >
                                    <span>#{t.name}</span>
                                    <span class:list={[
                                        "text-[9px] px-1.5 py-0.5 rounded-full",
                                        t.active ? "bg-red/20 text-red" : "bg-dark-300 text-gray-600"
                                    ]}>
                                        {t.count}
                                    </span>
                                </a>
                            ))}
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </section>

</Layout>
