---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Generador de Posts">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-10">

        <!-- ===== HEADER ===== -->
        <div class="mb-10">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-3">
                <div>
                    <h1 class="text-3xl font-black text-white tracking-tight">Generador de Posts</h1>
                    <p class="text-sm text-gray-500 mt-1">Crea, previsualiza y publica artículos directamente en el sitio.</p>
                </div>
                <div class="flex items-center gap-2">
                    <button id="btn-help" class="flex items-center gap-2 bg-dark-100 border border-dark-300 text-gray-400 hover:text-white hover:border-red text-xs font-mono px-4 py-2.5 rounded-lg transition-all cursor-pointer" title="Guía de uso">
                        <i class="bi bi-question-circle"></i> Ayuda
                    </button>
                    <button id="btn-git-config" class="flex items-center gap-2 bg-dark-100 border border-dark-300 text-gray-400 hover:text-white hover:border-red text-xs font-mono px-4 py-2.5 rounded-lg transition-all cursor-pointer" title="Configurar GitHub">
                        <i class="bi bi-github"></i> GitHub
                    </button>
                </div>
            </div>
            <!-- Steps indicator -->
            <div class="flex items-center gap-0 text-[10px] font-mono text-gray-600 uppercase tracking-widest">
                <span class="flex items-center gap-1.5 text-red"><span class="w-5 h-5 rounded-full bg-red border border-red flex items-center justify-center text-red font-bold">1</span> Metadatos</span>
                <span class="w-8 h-px bg-dark-300 mx-2"></span>
                <span class="flex items-center gap-1.5" id="step-2-label"><span class="w-5 h-5 rounded-full bg-dark-200 border border-dark-300 flex items-center justify-center font-bold">2</span> Contenido</span>
                <span class="w-8 h-px bg-dark-300 mx-2"></span>
                <span class="flex items-center gap-1.5" id="step-3-label"><span class="w-5 h-5 rounded-full bg-dark-200 border border-dark-300 flex items-center justify-center font-bold">3</span> Publicar</span>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

            <!-- ===== SIDEBAR: METADATOS ===== -->
            <aside class="lg:col-span-4 xl:col-span-3">
                <div class="bg-dark-100 border border-dark-300 rounded-xl p-6 sticky top-20">
                    <h3 class="text-xs font-mono font-bold text-red uppercase tracking-widest mb-6 flex items-center gap-2">
                        <i class="bi bi-gear-fill"></i> Metadatos del post
                    </h3>

                    <!-- Título -->
                    <div class="mb-4">
                        <label for="post-title" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                            Título <span class="text-red">*</span>
                        </label>
                        <input type="text" id="post-title" placeholder="Ej: Análisis del malware XYZ..." class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                        <p class="text-[10px] text-gray-600 mt-1">El título principal de tu artículo</p>
                    </div>

                    <!-- Slug -->
                    <div class="mb-4">
                        <label for="post-slug" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                            Slug (URL) <span class="text-red">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-600 text-[11px] font-mono">/posts/</span>
                            <input type="text" id="post-slug" placeholder="analisis-malware-xyz" class="w-full bg-dark border border-dark-300 rounded-lg pl-16 pr-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                        </div>
                        <p class="text-[10px] text-gray-600 mt-1">Se genera automáticamente desde el título</p>
                    </div>

                    <!-- Categoría + Tiempo lectura -->
                    <div class="grid grid-cols-2 gap-3 mb-4">
                        <div>
                            <label for="post-category" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                                Categoría <span class="text-red">*</span>
                            </label>
                            <select id="post-category" class="w-full bg-dark border border-dark-300 rounded-lg px-3 py-2.5 text-sm text-gray-200 focus:border-red focus:outline-none transition-colors font-mono appearance-none cursor-pointer">
                                <option value="MALWARE ANALYSIS">Malware</option>
                                <option value="NETWORKING">Redes</option>
                                <option value="DEFENSIVE OPS">Defensivo</option>
                                <option value="INTEL">Inteligencia</option>
                                <option value="OSINT">OSINT</option>
                                <option value="PENTESTING">Pentesting</option>
                                <option value="WRITEUPS CTF">Writeups de CTF</option>
                                <option value="PROGRAMACIÓN">Programación</option>
                            </select>
                        </div>
                        <div>
                            <label for="post-readtime" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                                Lectura
                            </label>
                            <input type="text" id="post-readtime" value="5 MIN READ" class="w-full bg-dark border border-dark-300 rounded-lg px-3 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                        </div>
                    </div>

                    <!-- Autor -->
                    <div class="mb-4">
                        <label for="post-author" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                            Autor
                        </label>
                        <input type="text" id="post-author" value="ADMIN" placeholder="Tu alias..." class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                    </div>

                    <!-- URL Imagen -->
                    <div class="mb-4">
                        <label for="post-image" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                            URL Imagen
                        </label>
                        <input type="url" id="post-image" placeholder="https://images.unsplash.com/..." class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                        <p class="text-[10px] text-gray-600 mt-1">Usa <a href="https://unsplash.com" target="_blank" class="text-red hover:text-red">Unsplash</a> para imágenes gratuitas</p>
                    </div>

                    <!-- Tags -->
                    <div class="mb-4">
                        <label class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                            Tags
                        </label>
                        <div class="flex flex-wrap gap-1.5 mb-2 min-h-[28px]" id="tags-container"></div>
                        <div class="flex gap-2">
                            <input type="text" id="tag-input" placeholder="Agregar tag..." class="flex-grow bg-dark border border-dark-300 rounded-lg px-3 py-2 text-xs text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                            <button id="add-tag-btn" class="bg-dark-200 border border-dark-300 hover:border-red text-gray-400 hover:text-red text-xs px-3 py-2 rounded-lg transition-all cursor-pointer">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        <p class="text-[10px] text-gray-600 mt-1">Enter o click en + para agregar</p>
                    </div>

                    <!-- Resumen -->
                    <div class="mb-6">
                        <label for="post-summary" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">
                            Resumen <span class="text-red">*</span>
                        </label>
                        <textarea id="post-summary" rows="3" placeholder="Una breve descripción del artículo..." class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono resize-none"></textarea>
                    </div>

                    <!-- Image Preview -->
                    <div id="image-preview-box" class="mb-6 hidden">
                        <div class="aspect-video rounded-lg overflow-hidden border border-dark-300">
                            <img id="image-preview" src="" alt="Preview" class="w-full h-full object-cover">
                        </div>
                    </div>

                </div>
            </aside>

            <!-- ===== MAIN: EDITOR + PREVIEW ===== -->
            <div class="lg:col-span-8 xl:col-span-9">

                <!-- Tabs -->
                <div class="flex items-center justify-between mb-4">
                    <div class="flex gap-1 bg-dark-100 border border-dark-300 rounded-lg p-1">
                        <button class="editor-tab active px-5 py-2 text-[11px] font-bold uppercase tracking-wider rounded-md cursor-pointer transition-all text-gray-400" data-tab="edit">
                            <i class="bi bi-code-slash me-1"></i> Editor
                        </button>
                        <button class="editor-tab px-5 py-2 text-[11px] font-bold uppercase tracking-wider rounded-md cursor-pointer transition-all text-gray-400" data-tab="preview">
                            <i class="bi bi-eye me-1"></i> Preview
                        </button>
                        <button class="editor-tab px-5 py-2 text-[11px] font-bold uppercase tracking-wider rounded-md cursor-pointer transition-all text-gray-400" data-tab="raw">
                            <i class="bi bi-file-earmark-code me-1"></i> Raw .md
                        </button>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] font-mono text-gray-600">
                        <span id="char-count">0</span> caracteres
                        <span class="text-dark-300">·</span>
                        <span id="word-count">0</span> palabras
                    </div>
                </div>

                <!-- Markdown Toolbar -->
                <div class="flex flex-wrap items-center gap-1 bg-dark-100 border border-dark-300 rounded-t-xl px-3 py-2" id="md-toolbar">
                    <button class="md-btn" data-action="h2" title="Encabezado H2"><i class="bi bi-type-h2"></i></button>
                    <button class="md-btn" data-action="h3" title="Encabezado H3"><i class="bi bi-type-h3"></i></button>
                    <span class="w-px h-5 bg-dark-300 mx-1"></span>
                    <button class="md-btn" data-action="bold" title="Negrita (Ctrl+B)"><i class="bi bi-type-bold"></i></button>
                    <button class="md-btn" data-action="italic" title="Cursiva (Ctrl+I)"><i class="bi bi-type-italic"></i></button>
                    <button class="md-btn" data-action="code" title="Código inline"><i class="bi bi-code"></i></button>
                    <span class="w-px h-5 bg-dark-300 mx-1"></span>
                    <button class="md-btn" data-action="ul" title="Lista con viñetas"><i class="bi bi-list-ul"></i></button>
                    <button class="md-btn" data-action="ol" title="Lista numerada"><i class="bi bi-list-ol"></i></button>
                    <button class="md-btn" data-action="quote" title="Cita"><i class="bi bi-blockquote-left"></i></button>
                    <span class="w-px h-5 bg-dark-300 mx-1"></span>
                    <button class="md-btn" data-action="link" title="Enlace"><i class="bi bi-link-45deg"></i></button>
                    <button class="md-btn" data-action="image" title="Imagen"><i class="bi bi-image"></i></button>
                    <button class="md-btn" data-action="codeblock" title="Bloque de código"><i class="bi bi-file-earmark-code"></i></button>
                    <span class="w-px h-5 bg-dark-300 mx-1"></span>
                    <button class="md-btn" data-action="hr" title="Línea separadora"><i class="bi bi-dash-lg"></i></button>
                    <button class="md-btn" data-action="table" title="Tabla"><i class="bi bi-table"></i></button>
                </div>

                <!-- Editor pane -->
                <div id="pane-edit" class="tab-pane">
                    <textarea id="editor" placeholder="# Escribe tu artículo aquí...&#10;&#10;Usa Markdown para dar formato. Si no conoces Markdown, usa la barra de herramientas de arriba.&#10;&#10;## Ejemplo de sección&#10;&#10;- Punto importante 1&#10;- Punto importante 2&#10;&#10;```python&#10;print('Hola mundo')&#10;```" class="w-full bg-dark border border-dark-300 border-t-0 rounded-b-xl px-6 py-5 text-sm text-gray-200 placeholder:text-gray-600 focus:outline-none font-mono leading-relaxed resize-none" style="min-height: 550px;"></textarea>
                </div>

                <!-- Preview pane -->
                <div id="pane-preview" class="tab-pane hidden">
                    <div class="bg-dark border border-dark-300 border-t-0 rounded-b-xl px-8 py-6 post-content" style="min-height: 550px;" id="preview-content">
                        <p class="text-gray-600 italic">El preview aparecerá aquí mientras escribes...</p>
                    </div>
                </div>

                <!-- Raw .md pane -->
                <div id="pane-raw" class="tab-pane hidden">
                    <pre class="bg-dark border border-dark-300 border-t-0 rounded-b-xl px-6 py-5 text-xs text-gray-400 font-mono overflow-x-auto whitespace-pre-wrap" style="min-height: 550px;" id="raw-content">El archivo .md generado aparecerá aquí...</pre>
                </div>

                <!-- ===== ACTION BUTTONS ===== -->
                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 mt-6">
                    <button id="btn-validate" class="flex-1 flex items-center justify-center gap-2 bg-dark-100 border border-dark-300 hover:border-green-500/40 text-gray-300 hover:text-green-400 font-bold text-sm px-6 py-3.5 rounded-lg transition-all cursor-pointer">
                        <i class="bi bi-check-circle"></i> Validar datos
                    </button>
                    <button id="btn-download" class="flex-1 flex items-center justify-center gap-2 bg-dark-100 border border-dark-300 hover:border-red text-gray-300 hover:text-red font-bold text-sm px-6 py-3.5 rounded-lg transition-all cursor-pointer">
                        <i class="bi bi-download"></i> Descargar .md
                    </button>
                    <button id="btn-publish" class="flex-1 flex items-center justify-center gap-2 bg-red hover:bg-red-dark text-white font-bold text-sm px-6 py-3.5 rounded-lg transition-all cursor-pointer hover:-translate-y-0.5">
                        <i class="bi bi-cloud-upload"></i> Publicar en GitHub
                    </button>
                </div>

                <!-- Status messages -->
                <div id="status-bar" class="mt-4 hidden">
                    <div class="bg-dark-100 border border-dark-300 rounded-lg px-5 py-3 text-xs font-mono flex items-center gap-3">
                        <i id="status-icon" class="bi bi-info-circle text-gray-400"></i>
                        <span id="status-text" class="text-gray-400">Listo</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== HELP MODAL ===== -->
    <div id="modal-help" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="help-overlay"></div>
        <div class="relative z-10 flex items-center justify-center min-h-screen p-6">
            <div class="bg-dark-100 border border-dark-300 rounded-2xl w-full max-w-2xl max-h-[80vh] overflow-y-auto shadow-2xl">
                <div class="sticky top-0 bg-dark-100 border-b border-dark-300 px-6 py-4 flex items-center justify-between rounded-t-2xl">
                    <h2 class="text-lg font-bold text-white flex items-center gap-2"><i class="bi bi-question-circle text-red"></i> Guía de uso</h2>
                    <button id="close-help" class="text-gray-500 hover:text-white transition-colors cursor-pointer"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="p-6 text-sm text-gray-300 space-y-6">
                    <div>
                        <h3 class="text-white font-bold mb-2 flex items-center gap-2"><span class="w-6 h-6 rounded-full bg-red border border-red text-red text-xs flex items-center justify-center font-bold">1</span> Completa los metadatos</h3>
                        <p class="text-gray-400 ml-8">En el panel izquierdo, llena el <strong class="text-gray-200">título</strong>, <strong class="text-gray-200">resumen</strong> y los demás campos. El <strong class="text-gray-200">slug</strong> se genera solo desde el título (pero puedes editarlo).</p>
                    </div>
                    <div>
                        <h3 class="text-white font-bold mb-2 flex items-center gap-2"><span class="w-6 h-6 rounded-full bg-red border border-red text-red text-xs flex items-center justify-center font-bold">2</span> Escribe el contenido</h3>
                        <p class="text-gray-400 ml-8">Usa el editor para escribir tu artículo en <strong class="text-gray-200">Markdown</strong>. Si no conoces Markdown, usa la <strong class="text-gray-200">barra de herramientas</strong> de arriba del editor para insertar formato.</p>
                    </div>
                    <div>
                        <h3 class="text-white font-bold mb-2 flex items-center gap-2"><span class="w-6 h-6 rounded-full bg-red border border-red text-red text-xs flex items-center justify-center font-bold">3</span> Previsualiza</h3>
                        <p class="text-gray-400 ml-8">Haz click en <strong class="text-gray-200">"Preview"</strong> para ver cómo se verá tu artículo publicado. Revisa <strong class="text-gray-200">"Raw .md"</strong> para ver el archivo final que se generará.</p>
                    </div>
                    <div>
                        <h3 class="text-white font-bold mb-2 flex items-center gap-2"><span class="w-6 h-6 rounded-full bg-red border border-red text-red text-xs flex items-center justify-center font-bold">4</span> Publica</h3>
                        <p class="text-gray-400 ml-8">Usa <strong class="text-gray-200">"Validar datos"</strong> para verificar que todo esté correcto. Luego elige entre <strong class="text-gray-200">descargar</strong> el archivo o <strong class="text-gray-200">publicar directamente</strong> en GitHub.</p>
                    </div>
                    <div>
                        <h3 class="text-white font-bold mb-2 flex items-center gap-2"><span class="w-6 h-6 rounded-full bg-red border border-red text-red text-xs flex items-center justify-center font-bold">5</span> ¿Dónde guardar si descargas?</h3>
                        <p class="text-gray-400 ml-8">Si eliges descargar el archivo <strong class="text-gray-200">.md</strong>, DEBES guardarlo/moverlo exclusivamente a la carpeta <strong class="text-gray-200 text-red border border-red/40 bg-red/10 px-2 py-1 rounded">src/content/blog/</strong>. Astro ignorará los posts que se pongan en /posts/ o cualquier otro sitio.</p>
                    </div>
                    <hr class="border-dark-300">
                    <div>
                        <h3 class="text-white font-bold mb-2"><i class="bi bi-markdown text-red me-1"></i> Guía rápida Markdown</h3>
                        <div class="bg-dark rounded-lg p-4 font-mono text-xs text-gray-400 space-y-1.5">
                            <p><span class="text-red"># Título</span> → Encabezado grande</p>
                            <p><span class="text-red">## Subtítulo</span> → Encabezado mediano</p>
                            <p><span class="text-red">**texto**</span> → <strong class="text-gray-200">Negrita</strong></p>
                            <p><span class="text-red">*texto*</span> → <em>Cursiva</em></p>
                            <p><span class="text-red">`código`</span> → <code class="bg-dark-200 px-1 rounded text-red">código</code></p>
                            <p><span class="text-red">- item</span> → Lista con viñetas</p>
                            <p><span class="text-red">[texto](url)</span> → Enlace</p>
                            <p><span class="text-red">![alt](url)</span> → Imagen</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== GIT CONFIG MODAL ===== -->
    <div id="modal-git" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="git-overlay"></div>
        <div class="relative z-10 flex items-center justify-center min-h-screen p-6">
            <div class="bg-dark-100 border border-dark-300 rounded-2xl w-full max-w-lg shadow-2xl">
                <div class="border-b border-dark-300 px-6 py-4 flex items-center justify-between rounded-t-2xl">
                    <h2 class="text-lg font-bold text-white flex items-center gap-2"><i class="bi bi-github text-red"></i> Configuración GitHub</h2>
                    <button id="close-git" class="text-gray-500 hover:text-white transition-colors cursor-pointer"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="p-6 space-y-4">
                    <div class="bg-dark rounded-lg border border-dark-300 px-4 py-3 text-xs text-gray-400">
                        <i class="bi bi-info-circle text-red me-1"></i>
                        Necesitas un <a href="https://github.com/settings/tokens/new" target="_blank" class="text-red hover:underline">Personal Access Token</a> de GitHub con permisos de <strong class="text-gray-200">repo</strong> (contenido y commit). La configuración se guarda localmente en tu navegador.
                    </div>

                    <div>
                        <label for="git-token" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">Token de acceso <span class="text-red">*</span></label>
                        <input type="password" id="git-token" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                    </div>
                    <div>
                        <label for="git-owner" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">Usuario / Organización <span class="text-red">*</span></label>
                        <input type="text" id="git-owner" placeholder="tu-usuario" class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                    </div>
                    <div>
                        <label for="git-repo" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">Repositorio <span class="text-red">*</span></label>
                        <input type="text" id="git-repo" placeholder="h4ck.cl" class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                    </div>
                    <div>
                        <label for="git-branch" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">Branch</label>
                        <input type="text" id="git-branch" value="main" class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                    </div>
                    <div>
                        <label for="git-path" class="block text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-1.5">Ruta de los posts</label>
                        <input type="text" id="git-path" value="src/content/blog" class="w-full bg-dark border border-dark-300 rounded-lg px-4 py-2.5 text-sm text-gray-200 placeholder:text-gray-600 focus:border-red focus:outline-none transition-colors font-mono">
                        <p class="text-[10px] text-gray-600 mt-1">La carpeta donde se guardan los posts en Markdown</p>
                    </div>

                    <div class="flex gap-3 pt-2">
                        <button id="btn-test-git" class="flex-1 flex items-center justify-center gap-2 bg-dark border border-dark-300 hover:border-green-500/40 text-gray-300 hover:text-green-400 font-bold text-sm px-4 py-3 rounded-lg transition-all cursor-pointer">
                            <i class="bi bi-plug"></i> Probar conexión
                        </button>
                        <button id="btn-save-git" class="flex-1 flex items-center justify-center gap-2 bg-red hover:bg-red-dark text-white font-bold text-sm px-4 py-3 rounded-lg transition-all cursor-pointer">
                            <i class="bi bi-check-lg"></i> Guardar
                        </button>
                    </div>
                    <div id="git-status" class="hidden text-xs font-mono px-3 py-2 rounded-lg"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== PUBLISH CONFIRM MODAL ===== -->
    <div id="modal-confirm" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="confirm-overlay"></div>
        <div class="relative z-10 flex items-center justify-center min-h-screen p-6">
            <div class="bg-dark-100 border border-dark-300 rounded-2xl w-full max-w-md shadow-2xl p-6 text-center">
                <div class="w-14 h-14 rounded-full bg-red border border-red flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-cloud-upload text-red text-2xl"></i>
                </div>
                <h2 class="text-xl font-bold text-white mb-2">¿Publicar en GitHub?</h2>
                <p class="text-sm text-gray-400 mb-2">Se creará el archivo:</p>
                <code class="text-xs font-mono text-red bg-dark rounded px-3 py-1.5 inline-block mb-4" id="confirm-path">src/content/blog/slug.md</code>
                <p class="text-xs text-gray-500 mb-6">en el repositorio <span id="confirm-repo" class="text-gray-300"></span></p>
                <div class="flex gap-3">
                    <button id="btn-cancel-publish" class="flex-1 bg-dark border border-dark-300 text-gray-300 hover:text-white font-bold text-sm py-3 rounded-lg transition-all cursor-pointer">Cancelar</button>
                    <button id="btn-confirm-publish" class="flex-1 bg-red hover:bg-red-dark text-white font-bold text-sm py-3 rounded-lg transition-all cursor-pointer">Publicar ahora</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== SUCCESS MODAL ===== -->
    <div id="modal-success" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="success-overlay"></div>
        <div class="relative z-10 flex items-center justify-center min-h-screen p-6">
            <div class="bg-dark-100 border border-dark-300 rounded-2xl w-full max-w-md shadow-2xl p-8 text-center">
                <div class="w-16 h-16 rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center mx-auto mb-5 animate-bounce">
                    <i class="bi bi-check-lg text-green-400 text-3xl"></i>
                </div>
                <h2 class="text-2xl font-bold text-white mb-2">¡Publicado!</h2>
                <p class="text-sm text-gray-400 mb-6">Tu post ha sido subido exitosamente a GitHub. Los cambios pueden tardar unos minutos en reflejarse.</p>
                <a id="success-link" href="#" target="_blank" class="inline-flex items-center gap-2 bg-dark border border-dark-300 hover:border-green-500/40 text-gray-300 hover:text-green-400 font-bold text-sm px-6 py-3 rounded-lg transition-all no-underline mb-3">
                    <i class="bi bi-github"></i> Ver en GitHub
                </a>
                <br>
                <button id="close-success" class="text-gray-500 hover:text-white text-sm transition-colors mt-2 cursor-pointer">Cerrar</button>
            </div>
        </div>
    </div>

</Layout>

<style>
    /* Editor tab active state */
    .editor-tab.active {
        background-color: var(--color-red) !important;
        color: white !important;
    }

    /* Markdown toolbar buttons */
    .md-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        color: #6b7280;
        background: transparent;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.15s ease;
        font-size: 14px;
    }
    .md-btn:hover {
        color: white;
        background: var(--color-dark-200);
        border-color: var(--color-dark-300);
    }

    /* Tag pill */
    .tag-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--color-dark-200);
        border: 1px solid var(--color-dark-300);
        color: #9ca3af;
        font-family: var(--font-mono);
        font-size: 10px;
        padding: 2px 8px 2px 10px;
        border-radius: 999px;
        transition: all 0.15s ease;
    }
    .tag-pill:hover {
        border-color: var(--color-red);
    }
    .tag-pill .tag-remove {
        cursor: pointer;
        color: #6b7280;
        transition: color 0.15s ease;
    }
    .tag-pill .tag-remove:hover {
        color: var(--color-red);
    }

    /* Validation states */
    .field-error {
        border-color: var(--color-red) !important;
        box-shadow: 0 0 0 1px var(--color-red) inset;
    }
    .field-success {
        border-color: #22c55e !important;
    }

    /* Loading spinner */
    .spinner {
        display: inline-block;
        width: 14px;
        height: 14px;
        border: 2px solid #ffffff33;
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
    }
    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    /* Textarea auto-grow */
    #editor {
        field-sizing: content;
    }
</style>

<script>
    import { marked } from 'marked';

    // ===== DOM ELEMENTS =====
    const $ = (id: string) => document.getElementById(id);
    const titleEl = $('post-title') as HTMLInputElement;
    const slugEl = $('post-slug') as HTMLInputElement;
    const categoryEl = $('post-category') as HTMLSelectElement;
    const readtimeEl = $('post-readtime') as HTMLInputElement;
    const authorEl = $('post-author') as HTMLInputElement;
    const imageEl = $('post-image') as HTMLInputElement;
    const summaryEl = $('post-summary') as HTMLTextAreaElement;
    const editor = $('editor') as HTMLTextAreaElement;
    const previewContent = $('preview-content')!;
    const rawContent = $('raw-content')!;
    const tagsContainer = $('tags-container')!;
    const tagInput = $('tag-input') as HTMLInputElement;
    const charCount = $('char-count')!;
    const wordCount = $('word-count')!;
    const statusBar = $('status-bar')!;
    const statusIcon = $('status-icon')!;
    const statusText = $('status-text')!;

    // ===== STATE =====
    let tags: string[] = ['Intel'];

    // ===== SLUG AUTO-GENERATION =====
    function generateSlug(text: string): string {
        return text
            .toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '') // remove accents
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-|-$/g, '')
            .substring(0, 60);
    }

    let slugManuallyEdited = false;
    titleEl?.addEventListener('input', () => {
        if (!slugManuallyEdited) {
            slugEl.value = generateSlug(titleEl.value);
        }
    });
    slugEl?.addEventListener('input', () => {
        slugManuallyEdited = true;
    });
    slugEl?.addEventListener('blur', () => {
        if (!slugEl.value.trim()) slugManuallyEdited = false;
    });

    // ===== IMAGE PREVIEW =====
    const imagePreviewBox = $('image-preview-box')!;
    const imagePreview = $('image-preview') as HTMLImageElement;
    imageEl?.addEventListener('input', () => {
        const url = imageEl.value.trim();
        if (url) {
            imagePreview.src = url;
            imagePreviewBox.classList.remove('hidden');
            imagePreview.onerror = () => imagePreviewBox.classList.add('hidden');
        } else {
            imagePreviewBox.classList.add('hidden');
        }
    });

    // ===== TAGS =====
    function renderTags() {
        tagsContainer.innerHTML = tags.map(tag =>
            `<span class="tag-pill">#${tag} <span class="tag-remove" data-tag="${tag}"><i class="bi bi-x"></i></span></span>`
        ).join('');
        tagsContainer.querySelectorAll('.tag-remove').forEach(btn => {
            btn.addEventListener('click', () => {
                const tagToRemove = (btn as HTMLElement).dataset.tag!;
                tags = tags.filter(t => t !== tagToRemove);
                renderTags();
            });
        });
    }
    renderTags();

    function addTag() {
        const val = tagInput.value.trim().replace(/^#/, '');
        if (val && !tags.includes(val)) {
            tags.push(val);
            renderTags();
            tagInput.value = '';
        }
        tagInput.focus();
    }

    $('add-tag-btn')?.addEventListener('click', addTag);
    tagInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); addTag(); }
    });

    // ===== EDITOR TABS =====
    const editorTabs = document.querySelectorAll('.editor-tab');
    const panes = { edit: $('pane-edit')!, preview: $('pane-preview')!, raw: $('pane-raw')! };
    const toolbar = $('md-toolbar')!;

    editorTabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const target = (tab as HTMLElement).dataset.tab as keyof typeof panes;
            editorTabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            Object.values(panes).forEach(p => p.classList.add('hidden'));
            panes[target].classList.remove('hidden');

            // Show toolbar only on editor tab
            toolbar.style.display = target === 'edit' ? '' : 'none';

            // Update preview/raw on switch
            if (target === 'preview') updatePreview();
            if (target === 'raw') updateRaw();
        });
    });

    // ===== MARKDOWN TOOLBAR =====
    document.querySelectorAll('.md-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const action = (btn as HTMLElement).dataset.action!;
            insertMarkdown(action);
        });
    });

    function insertMarkdown(action: string) {
        if (!editor) return;
        const start = editor.selectionStart;
        const end = editor.selectionEnd;
        const selected = editor.value.substring(start, end);
        let before = '', after = '', insert = '';

        switch (action) {
            case 'h2': before = '\n## '; break;
            case 'h3': before = '\n### '; break;
            case 'bold': before = '**'; after = '**'; insert = selected || 'texto en negrita'; break;
            case 'italic': before = '*'; after = '*'; insert = selected || 'texto en cursiva'; break;
            case 'code': before = '`'; after = '`'; insert = selected || 'código'; break;
            case 'ul': before = '\n- '; insert = selected || 'Elemento de lista'; break;
            case 'ol': before = '\n1. '; insert = selected || 'Elemento numerado'; break;
            case 'quote': before = '\n> '; insert = selected || 'Cita'; break;
            case 'link': before = '['; after = '](url)'; insert = selected || 'texto del enlace'; break;
            case 'image': before = '!['; after = '](url)'; insert = selected || 'descripción'; break;
            case 'codeblock': before = '\n```\n'; after = '\n```\n'; insert = selected || 'tu código aquí'; break;
            case 'hr': before = '\n---\n'; break;
            case 'table':
                before = '\n| Columna 1 | Columna 2 | Columna 3 |\n| --- | --- | --- |\n| dato | dato | dato |\n';
                break;
        }

        const replacement = before + (insert || selected) + after;
        editor.setRangeText(replacement, start, end, 'end');
        editor.focus();
        updateCounts();
    }

    // Keyboard shortcuts
    editor?.addEventListener('keydown', (e) => {
        if (e.ctrlKey && e.key === 'b') { e.preventDefault(); insertMarkdown('bold'); }
        if (e.ctrlKey && e.key === 'i') { e.preventDefault(); insertMarkdown('italic'); }
        if (e.ctrlKey && e.key === 'k') { e.preventDefault(); insertMarkdown('link'); }
    });

    // ===== PREVIEW & COUNTS =====
    function updatePreview() {
        if (editor && previewContent) {
            const content = editor.value;
            if (content.trim()) {
                previewContent.innerHTML = marked.parse(content) as string;
            } else {
                previewContent.innerHTML = '<p class="text-gray-600 italic">El preview aparecerá aquí mientras escribes...</p>';
            }
        }
    }

    function updateCounts() {
        const text = editor?.value || '';
        charCount.textContent = text.length.toString();
        const words = text.trim().split(/\s+/).filter(w => w.length > 0);
        wordCount.textContent = words.length.toString();
    }

    editor?.addEventListener('input', () => {
        updateCounts();
    });

    // ===== GENERATE MARKDOWN FILE CONTENT =====
    function generateMarkdownFile(): string {
        const meta = {
            title: titleEl.value.trim() || 'Sin título',
            date: new Date().toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }).toUpperCase().replace(',', ''),
            category: categoryEl.value,
            author: authorEl.value.trim() || 'ADMIN',
            tags: tags,
            readTime: readtimeEl.value.trim() || '5 MIN READ',
            image: imageEl.value.trim() || 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=1200',
            summary: summaryEl.value.trim() || ''
        };

        return `---
title: "${meta.title}"
date: "${meta.date}"
category: "${meta.category}"
author: "${meta.author}"
tags: [${meta.tags.map(t => `"${t}"`).join(', ')}]
readTime: "${meta.readTime}"
image: "${meta.image}"
summary: "${meta.summary}"
---

${editor?.value || ''}`;
    }

    function updateRaw() {
        rawContent.textContent = generateMarkdownFile();
    }

    // ===== VALIDATION =====
    function validate(): { valid: boolean; errors: string[] } {
        const errors: string[] = [];
        const fields = [
            { el: titleEl, name: 'Título', required: true },
            { el: slugEl, name: 'Slug', required: true },
            { el: summaryEl, name: 'Resumen', required: true },
        ];

        // Clear previous states
        document.querySelectorAll('.field-error, .field-success').forEach(el => {
            el.classList.remove('field-error', 'field-success');
        });

        fields.forEach(f => {
            if (f.required && !f.el.value.trim()) {
                errors.push(`${f.name} es obligatorio`);
                f.el.classList.add('field-error');
            } else {
                f.el.classList.add('field-success');
            }
        });

        if (!editor.value.trim()) {
            errors.push('El contenido del editor está vacío');
            editor.classList.add('field-error');
        } else {
            editor.classList.add('field-success');
        }

        // Validate slug format
        if (slugEl.value.trim() && !/^[a-z0-9-]+$/.test(slugEl.value.trim())) {
            errors.push('El slug solo puede contener letras minúsculas, números y guiones (-)');
            slugEl.classList.remove('field-success');
            slugEl.classList.add('field-error');
        }

        return { valid: errors.length === 0, errors };
    }

    function showStatus(message: string, type: 'info' | 'success' | 'error' | 'loading') {
        statusBar.classList.remove('hidden');
        const icons: Record<string, string> = {
            info: 'bi-info-circle text-gray-400',
            success: 'bi-check-circle-fill text-green-400',
            error: 'bi-exclamation-triangle-fill text-red',
            loading: 'spinner'
        };
        const colors: Record<string, string> = {
            info: 'text-gray-400',
            success: 'text-green-400',
            error: 'text-red',
            loading: 'text-gray-300'
        };
        statusIcon.className = type === 'loading' ? 'spinner' : `bi ${icons[type]}`;
        statusText.className = colors[type];
        statusText.textContent = message;
    }

    // ===== VALIDATE BUTTON =====
    $('btn-validate')?.addEventListener('click', () => {
        const { valid, errors } = validate();
        if (valid) {
            showStatus('✓ Todos los campos están correctos. Listo para publicar.', 'success');
        } else {
            showStatus('✗ Errores: ' + errors.join(', '), 'error');
        }
    });

    // ===== DOWNLOAD =====
    $('btn-download')?.addEventListener('click', () => {
        const { valid, errors } = validate();
        if (!valid) {
            showStatus('✗ Corrige los errores antes de descargar: ' + errors.join(', '), 'error');
            return;
        }
        const markdown = generateMarkdownFile();
        const blob = new Blob([markdown], { type: 'text/markdown;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${slugEl.value.trim() || 'new-post'}.md`;
        a.click();
        URL.revokeObjectURL(url);
        showStatus(`✓ Archivo descargado. DEBES moverlo a "src/content/blog/" para que el sitio lo muestre.`, 'success');
    });

    // ===== GITHUB CONFIG =====
    const GIT_KEY = 'h4ck_git_config';

    function loadGitConfig() {
        try {
            const saved = localStorage.getItem(GIT_KEY);
            if (saved) {
                const config = JSON.parse(saved);
                ($('git-token') as HTMLInputElement).value = config.token || '';
                ($('git-owner') as HTMLInputElement).value = config.owner || '';
                ($('git-repo') as HTMLInputElement).value = config.repo || '';
                ($('git-branch') as HTMLInputElement).value = config.branch || 'main';
                ($('git-path') as HTMLInputElement).value = config.path || 'src/content/blog';
            }
        } catch {}
    }

    function saveGitConfig() {
        const config = {
            token: ($('git-token') as HTMLInputElement).value.trim(),
            owner: ($('git-owner') as HTMLInputElement).value.trim(),
            repo: ($('git-repo') as HTMLInputElement).value.trim(),
            branch: ($('git-branch') as HTMLInputElement).value.trim() || 'main',
            path: ($('git-path') as HTMLInputElement).value.trim() || 'src/content/blog',
        };
        localStorage.setItem(GIT_KEY, JSON.stringify(config));
        return config;
    }

    function getGitConfig() {
        try {
            return JSON.parse(localStorage.getItem(GIT_KEY) || '{}');
        } catch { return {}; }
    }

    // Modals
    function toggleModal(id: string, show: boolean) {
        const modal = $(id);
        if (modal) {
            if (show) {
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }
        }
    }

    // Help modal
    $('btn-help')?.addEventListener('click', () => toggleModal('modal-help', true));
    $('close-help')?.addEventListener('click', () => toggleModal('modal-help', false));
    $('help-overlay')?.addEventListener('click', () => toggleModal('modal-help', false));

    // Git config modal
    $('btn-git-config')?.addEventListener('click', () => { loadGitConfig(); toggleModal('modal-git', true); });
    $('close-git')?.addEventListener('click', () => toggleModal('modal-git', false));
    $('git-overlay')?.addEventListener('click', () => toggleModal('modal-git', false));

    // Save git
    $('btn-save-git')?.addEventListener('click', () => {
        const config = saveGitConfig();
        const gitStatus = $('git-status')!;
        if (!config.token || !config.owner || !config.repo) {
            gitStatus.classList.remove('hidden');
            gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-red text-red border border-red';
            gitStatus.textContent = '✗ Token, usuario y repositorio son obligatorios';
            return;
        }
        gitStatus.classList.remove('hidden');
        gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-green-500/10 text-green-400 border border-green-500/20';
        gitStatus.textContent = '✓ Configuración guardada correctamente';
        setTimeout(() => toggleModal('modal-git', false), 1200);
    });

    // Test git connection
    $('btn-test-git')?.addEventListener('click', async () => {
        const config = saveGitConfig();
        const gitStatus = $('git-status')!;
        if (!config.token || !config.owner || !config.repo) {
            gitStatus.classList.remove('hidden');
            gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-red text-red border border-red';
            gitStatus.textContent = '✗ Completa todos los campos obligatorios primero';
            return;
        }
        gitStatus.classList.remove('hidden');
        gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-dark text-gray-300 border border-dark-300';
        gitStatus.innerHTML = '<span class="spinner mr-2"></span> Probando conexión...';

        try {
            const res = await fetch(`https://api.github.com/repos/${config.owner}/${config.repo}`, {
                headers: { 'Authorization': `Bearer ${config.token}`, 'Accept': 'application/vnd.github.v3+json' }
            });
            if (res.ok) {
                const data = await res.json();
                gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-green-500/10 text-green-400 border border-green-500/20';
                gitStatus.textContent = `✓ Conexión exitosa → ${data.full_name} (${data.visibility})`;
            } else {
                const err = await res.json();
                gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-red text-red border border-red';
                gitStatus.textContent = `✗ Error ${res.status}: ${err.message || 'No se pudo conectar'}`;
            }
        } catch (e) {
            gitStatus.className = 'text-xs font-mono px-3 py-2 rounded-lg bg-red text-red border border-red';
            gitStatus.textContent = `✗ Error de red: ${(e as Error).message}`;
        }
    });

    // ===== PUBLISH TO GITHUB =====
    $('btn-publish')?.addEventListener('click', () => {
        const { valid, errors } = validate();
        if (!valid) {
            showStatus('✗ Corrige los errores antes de publicar: ' + errors.join(', '), 'error');
            return;
        }

        const config = getGitConfig();
        if (!config.token || !config.owner || !config.repo) {
            showStatus('✗ Configura GitHub primero (botón GitHub en la parte superior)', 'error');
            toggleModal('modal-git', true);
            loadGitConfig();
            return;
        }

        const slug = slugEl.value.trim() || 'new-post';
        const filePath = `${config.path}/${slug}.md`;
        ($('confirm-path') as HTMLElement).textContent = filePath;
        ($('confirm-repo') as HTMLElement).textContent = `${config.owner}/${config.repo}`;
        toggleModal('modal-confirm', true);
    });

    // Cancel publish
    $('btn-cancel-publish')?.addEventListener('click', () => toggleModal('modal-confirm', false));
    $('confirm-overlay')?.addEventListener('click', () => toggleModal('modal-confirm', false));

    // Confirm publish
    $('btn-confirm-publish')?.addEventListener('click', async () => {
        toggleModal('modal-confirm', false);
        const config = getGitConfig();
        const slug = slugEl.value.trim() || 'new-post';
        const filePath = `${config.path}/${slug}.md`;
        const markdown = generateMarkdownFile();

        showStatus('Subiendo archivo a GitHub...', 'loading');

        try {
            // Check if file exists first
            const checkRes = await fetch(
                `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${filePath}?ref=${config.branch || 'main'}`,
                { headers: { 'Authorization': `Bearer ${config.token}`, 'Accept': 'application/vnd.github.v3+json' } }
            );

            let sha: string | undefined;
            if (checkRes.ok) {
                const existingFile = await checkRes.json();
                sha = existingFile.sha;
            }

            // Create or update file
            const body: Record<string, string> = {
                message: sha ? `update: ${slug}` : `new post: ${slug}`,
                content: btoa(unescape(encodeURIComponent(markdown))),
                branch: config.branch || 'main',
            };
            if (sha) body.sha = sha;

            const res = await fetch(
                `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${filePath}`,
                {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${config.token}`,
                        'Accept': 'application/vnd.github.v3+json',
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(body),
                }
            );

            if (res.ok) {
                const data = await res.json();
                showStatus('✓ ¡Post publicado exitosamente en GitHub!', 'success');
                ($('success-link') as HTMLAnchorElement).href = data.content.html_url;
                toggleModal('modal-success', true);
            } else {
                const err = await res.json();
                showStatus(`✗ Error al publicar: ${err.message || 'Error desconocido'}`, 'error');
            }
        } catch (e) {
            showStatus(`✗ Error de red: ${(e as Error).message}`, 'error');
        }
    });

    // Success modal
    $('close-success')?.addEventListener('click', () => toggleModal('modal-success', false));
    $('success-overlay')?.addEventListener('click', () => toggleModal('modal-success', false));

    // ===== ESCAPE KEY TO CLOSE MODALS =====
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            ['modal-help', 'modal-git', 'modal-confirm', 'modal-success'].forEach(id => toggleModal(id, false));
        }
    });

    // ===== INIT =====
    updateCounts();
</script>
